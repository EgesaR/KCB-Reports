generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql" // Changed from "sqlite"
  url      = env("DATABASE_URL")
  relationMode = "prisma" // Optional: Emulates relations in Prisma Client
}

model Blog {
  id          String   @id @default(uuid())
  name        String
  description String
  imageUrl    String?
  selfLink    String?
  publishedAt DateTime
  updatedAt   DateTime @updatedAt
  posts       Post[]
  pages       Page[]
}

model Post {
  id          String     @id @default(uuid())
  title       String
  content     String
  blogId      String
  blog        Blog       @relation(fields: [blogId], references: [id])
  categories  Category[] @relation("PostCategories")
  publishedAt DateTime   @default(now())
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  @@index([blogId]) // Index for performance
}

model Category {
  id    String @id @default(uuid())
  name  String @unique
  posts Post[] @relation("PostCategories")
}

model Page {
  id          String   @id @default(uuid())
  title       String
  content     String
  blogId      String
  blog        Blog     @relation(fields: [blogId], references: [id])
  publishedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@index([blogId]) // Index for performance
}