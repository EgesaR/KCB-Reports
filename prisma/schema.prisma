// ======================
// Configuration
// ======================
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider     = "mysql"
  url          = env("DATABASE_URL")
  relationMode = "prisma"
}

// ======================
// Enums
// ======================
enum RoleEnum {
  ADMIN
  PARENT
  TEACHER
  STUDENT
}

enum PostStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum NotificationType {
  INFO
  WARNING
  ERROR
  TEST
  GENERAL
  ALERT
  SUCCESS
}

enum ThemePreference {
  LIGHT
  DARK
  SYSTEM
}

// ======================
// User Domain (Enhanced)
// ======================
model User {
  id                 String          @id @default(uuid())
  name               String          @db.VarChar(100)
  email              String          @unique @db.VarChar(255)
  password           String          @db.VarChar(255)
  profileUrl         String?         @db.VarChar(512)
  profilePicture     String?         @db.VarChar(512)
  dob                DateTime?
  title              String?         @db.VarChar(100)  // Added for settings
  contact            String?         @db.VarChar(100)  // Added for settings
  department         String?         @db.VarChar(100)  // Added for settings
  studentId          String?         @db.VarChar(50)   // Added for settings
  themePreference    ThemePreference @default(SYSTEM)  // Added for settings
  accentColor        String?         @default("#3b82f6") // Added for settings
  highContrast       Boolean         @default(false)   // Added for settings
  reportFont         String?         @default("Arial") // Added for settings
  institutionalLogo  String?         @db.VarChar(512)  // Added for settings
  twoFactorEnabled   Boolean         @default(false)   // Added for settings
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  roles              UserRole[]
  adminRoles         UserAdminRole[]
  teacherProfile     TeacherProfile?
  reportTasks        ReportTask[]    @relation("AdminReportTasks")
  teacherReportTasks ReportTask[]    @relation("TeacherReportTasks")
  teacherMarks       Mark[]          @relation("TeacherMarks")
  adminMarks         Mark[]          @relation("AdminMarks")
  parentMarks        Mark[]          @relation("ParentMarks")
  students           UserStudent[]
  notifications      Notification[]  @relation("UserNotifications")
  sessions           Session[]       // Added for session management
  userSubjects       UserSubject[]   // Added for subjects association

  @@index([email])
  @@index([createdAt])
}

// Added for session management
model Session {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  ipAddress String
  userAgent String
  createdAt DateTime @default(now())
  expiresAt DateTime
  
  @@index([userId])
  @@index([expiresAt])
}

// Enhanced Subject model for many-to-many with users
model Subject {
  id          Int          @id @default(autoincrement())
  name        String       @unique @db.VarChar(50)
  description String?      @db.Text
  userSubjects UserSubject[]

  @@index([name])
}

model UserSubject {
  userId    String
  subjectId Int
  user      User     @relation(fields: [userId], references: [id])
  subject   Subject  @relation(fields: [subjectId], references: [id])

  @@id([userId, subjectId])
  @@index([subjectId])
}

// ======================
// Rest of your models (unchanged)
// ======================
model AdminRole {
  id        Int             @id @default(autoincrement())
  roleName  String          @unique @db.VarChar(50)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  userRoles UserAdminRole[]

  @@index([roleName])
}

model Blog {
  id          String   @id @default(uuid())
  name        String   @db.VarChar(100)
  description String   @db.Text
  imageUrl    String?  @db.VarChar(512)
  selfLink    String?  @db.VarChar(512)
  publishedAt DateTime
  updatedAt   DateTime @updatedAt
  posts       Post[]
  pages       Page[]

  @@index([publishedAt])
  @@index([updatedAt])
}

model Post {
  id               String           @id @default(uuid())
  slug             String           @unique @db.VarChar(255)
  title            String           @db.VarChar(200)
  imageUrl         String?          @db.VarChar(512)
  author           String           @db.VarChar(100)
  publishedAt      DateTime         @default(now())
  readingTime      Int?
  introduction     String?          @db.Text
  content          String           @db.Text
  tableOfContents  Json?
  conclusion       String?          @db.Text
  authorBio        String?          @db.VarChar(200)
  blogId           String
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  status           PostStatus       @default(PUBLISHED)
  blog             Blog             @relation(fields: [blogId], references: [id])
  categories       PostCategories[]
  relatedPostsFrom RelatedPosts[]   @relation("PostToRelatedPosts")
  relatedPostsTo   RelatedPosts[]   @relation("PostToRelatedPosts_Related")

  @@index([blogId])
  @@index([slug])
  @@index([publishedAt])
  @@index([status])
  @@index([author])
}

model Category {
  id    String           @id @default(uuid())
  name  String           @unique @db.VarChar(50)
  posts PostCategories[]

  @@index([name])
}

model Page {
  id          String   @id @default(uuid())
  title       String   @db.VarChar(200)
  content     String   @db.Text
  blogId      String
  publishedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt
  blog        Blog     @relation(fields: [blogId], references: [id])

  @@index([blogId])
  @@index([title])
}

model PostCategories {
  postId     String
  categoryId String
  post       Post     @relation(fields: [postId], references: [id])
  category   Category @relation(fields: [categoryId], references: [id])

  @@id([postId, categoryId])
  @@index([categoryId])
}

model RelatedPosts {
  postId        String
  relatedPostId String
  post          Post   @relation("PostToRelatedPosts", fields: [postId], references: [id])
  relatedPost   Post   @relation("PostToRelatedPosts_Related", fields: [relatedPostId], references: [id])

  @@id([postId, relatedPostId])
  @@index([relatedPostId])
}

model UserRole {
  id     String   @id @default(uuid())
  role   RoleEnum
  userId String
  user   User     @relation(fields: [userId], references: [id])

  @@unique([userId, role])
  @@index([role])
}

model Notification {
  id        String           @id @default(uuid())
  title     String
  message   String
  type      NotificationType @default(GENERAL)
  userId    String
  user      User             @relation("UserNotifications", fields: [userId], references: [id])
  date      DateTime         @default(now())
  read      Boolean          @default(false)
  archived  Boolean          @default(false)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  metadata  Json?

  @@index([userId])
  @@index([type])
  @@index([date])
  @@map("notifications")
}

model School {
  id        String   @id @default(uuid())
  name      String   @unique @db.VarChar(100)
  address   String?  @db.VarChar(255)
  badgeUrl  String?  @db.VarChar(512)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
}

model SchoolAssociation {
  id        String   @id @default(uuid())
  userId    String
  schoolId  String
  createdAt DateTime @default(now())

  @@unique([userId, schoolId])
  @@index([schoolId])
}

model Class {
  id   Int    @id @default(autoincrement())
  name String @unique @db.VarChar(50)

  @@index([name])
}

model Student {
  id        String        @id @default(uuid())
  name      String        @db.VarChar(100)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  marks     Mark[]
  users     UserStudent[]

  @@index([name])
}

model Mark {
  id              String   @id @default(uuid())
  subject         String   @db.VarChar(50)
  examinationName String   @db.VarChar(100)
  mark            Float
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  studentId       String
  teacherId       String?
  adminId         String?
  parentId        String?
  student         Student  @relation(fields: [studentId], references: [id])
  teacher         User?    @relation("TeacherMarks", fields: [teacherId], references: [id])
  admin           User?    @relation("AdminMarks", fields: [adminId], references: [id])
  parent          User?    @relation("ParentMarks", fields: [parentId], references: [id])

  @@index([studentId])
  @@index([subject])
  @@index([createdAt])
}

model TeacherProfile {
  id              String                       @id @default(uuid())
  userId          String                       @unique
  subjects        String                       @db.Text
  classes         String                       @db.Text
  streams         String                       @db.Text
  departmentGroup String?                      @db.VarChar(100)
  createdAt       DateTime                     @default(now())
  updatedAt       DateTime                     @updatedAt
  user            User                         @relation(fields: [userId], references: [id])
  departments     DepartmentToTeacherProfile[]

  @@index([userId])
}

model Department {
  id              String                       @id @default(uuid())
  name            String                       @db.VarChar(100)
  createdAt       DateTime                     @default(now())
  updatedAt       DateTime                     @updatedAt
  teacherProfiles DepartmentToTeacherProfile[]

  @@index([name])
}

model ReportTask {
  id          String   @id @default(uuid())
  title       String   @db.VarChar(200)
  description String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String
  teacherId   String?
  createdBy   User     @relation("AdminReportTasks", fields: [createdById], references: [id])
  teacher     User?    @relation("TeacherReportTasks", fields: [teacherId], references: [id])

  @@index([createdById])
  @@index([teacherId])
  @@index([createdAt])
}

model UserAdminRole {
  userId      String
  adminRoleId Int
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id])
  adminRole   AdminRole @relation(fields: [adminRoleId], references: [id])

  @@id([userId, adminRoleId])
  @@index([adminRoleId])
}

model UserStudent {
  userId    String
  studentId String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  student   Student  @relation(fields: [studentId], references: [id])

  @@id([userId, studentId])
  @@index([studentId])
}

model DepartmentToTeacherProfile {
  id           String         @id @default(uuid())
  department   Department     @relation(fields: [departmentId], references: [id])
  departmentId String
  profile      TeacherProfile @relation(fields: [profileId], references: [id])
  profileId    String
  createdAt    DateTime       @default(now())

  @@unique([departmentId, profileId])
  @@index([departmentId])
  @@index([profileId])
  @@map("department_teacher_profile")
}