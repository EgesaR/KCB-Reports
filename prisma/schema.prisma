generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider     = "mysql"
  url          = env("DATABASE_URL")
  relationMode = "prisma"
}

model Blog {
  id          String   @id @default(uuid())
  name        String
  description String
  imageUrl    String?
  selfLink    String?
  publishedAt DateTime
  updatedAt   DateTime @updatedAt
  posts       Post[]
  pages       Page[]
}

model Post {
  id          String     @id @default(uuid())
  title       String
  content     String
  blogId      String
  publishedAt DateTime   @default(now())
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  blog        Blog       @relation(fields: [blogId], references: [id])
  categories  Category[] @relation("PostCategories")

  @@index([blogId])
}

model Category {
  id    String @id @default(uuid())
  name  String @unique
  posts Post[] @relation("PostCategories")
}

model Page {
  id          String   @id @default(uuid())
  title       String
  content     String
  blogId      String
  publishedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt
  blog        Blog     @relation(fields: [blogId], references: [id])

  @@index([blogId])
}

model PostCategories {
  A String
  B String

  @@unique([A, B], map: "_PostCategories_AB_unique")
  @@index([B], map: "_PostCategories_B_index")
  @@map("_PostCategories")
}
